<h1>アカウント設定</h1>

<%= link_to "メールアドレスを変更する", edit_user_registration_path(anchor: "email") %>
<%= link_to "パスワードを変更する", edit_user_registration_path(anchor: "password") %>

<h2 id="email">メールアドレス変更</h2>
<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div>
    <%= f.label :email, "メールアドレス" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
  </div>

  <div>
    <%= f.label :current_password, "現在のパスワード（変更の確認に必要です）" %>
    <%= f.password_field :current_password, autocomplete: "current-password" %>
  </div>

  <div>
    <%= f.submit "メールアドレスを更新する" %>
  </div>
<% end %>

<h2 id="password">パスワード変更</h2>
<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <div>
    <%= f.label :password, "新しいパスワード" %>
    <%= f.password_field :password, autocomplete: "new-password" %>
    <% if @minimum_password_length %>
      <em><%= @minimum_password_length %>文字以上</em>
    <% end %>
  </div>

  <div>
    <%= f.label :password_confirmation, "新しいパスワード（確認）" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
  </div>

  <div>
    <%= f.label :current_password, "現在のパスワード" %>
    <%= f.password_field :current_password, autocomplete: "current-password" %>
  </div>

  <div>
    <%= f.submit "パスワードを更新する" %>
  </div>
<% end %>

<h2>アカウント削除</h2>
<%= button_to "アカウントを削除する", registration_path(resource_name), data: { turbo_confirm: "本当に削除しますか？削除すると元に戻せません。" }, method: :delete %>

<%= link_to "一覧に戻る", person_records_path %>
