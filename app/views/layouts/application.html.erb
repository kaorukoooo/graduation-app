<!DOCTYPE html>
<html>
  <head>
    <title>婚活きろく</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <header>
      <% if user_signed_in? %>
        <%= link_to "婚活きろく", person_records_path %>
        <%= link_to "記録一覧", person_records_path %>
        <%= link_to "タグ設定", tags_path %>
        <%= link_to "アカウント設定", edit_user_registration_path %>
        <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete } %>
      <% else %>
        <%= link_to "婚活きろく", top_path %>
        <%= link_to "新規登録", new_user_registration_path %>
        <%= link_to "ログイン", new_user_session_path %>
      <% end %>
    </header>

    <% if notice %>
      <p><%= notice %></p>
    <% end %>

    <%= yield %>

    <footer>
      <%= link_to "利用規約", terms_path %>
      <%= link_to "プライバシーポリシー", privacy_path %>
    </footer>
  </body>
</html>
